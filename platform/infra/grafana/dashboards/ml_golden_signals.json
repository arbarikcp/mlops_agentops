{
  "title": "ML Credit Risk \u2014 Golden Signals",
  "uid": "ml-golden-signals-v1",
  "description": "Four golden signals + ML quality panels for credit risk model",
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Prediction RPS",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(mlops_prediction_requests_total[1m])",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(mlops_prediction_errors_total[1m]) / rate(mlops_prediction_requests_total[1m])",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "p99 Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mlops_prediction_latency_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 500,
                "color": "yellow"
              },
              {
                "value": 1000,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "p50 Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(mlops_prediction_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Model AUC",
      "type": "stat",
      "targets": [
        {
          "expr": "mlops_model_auc",
          "legendFormat": "AUC",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.72,
                "color": "yellow"
              },
              {
                "value": 0.78,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Drift Score by Feature",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mlops_drift_score",
          "legendFormat": "{{{{feature}}}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 0.2,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Feature Freshness (hours)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mlops_feature_freshness_hours",
          "legendFormat": "{{{{view}}}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 25,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Approval Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "mlops_approval_rate",
          "legendFormat": "Approval Rate",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 0.7,
                "color": "green"
              }
            ]
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {}
}