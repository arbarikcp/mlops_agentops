# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.
# Threat model E-02: no plaintext credentials in code or git.

# MinIO / S3
MINIO_ROOT_USER=mlops_admin
MINIO_ROOT_PASSWORD=change_me_strong_password

# Postgres
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mlflow

# MLflow
MLFLOW_BUCKET=mlflow-artifacts

# DVC remote
DVC_REMOTE_URL=s3://dvc-data
